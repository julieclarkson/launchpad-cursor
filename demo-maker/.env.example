# Demo Maker API Keys
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# These keys never leave your machine. They are only used for API calls
# to generate voice narration and AI video clips. The AI agent cannot read this file.

# ── Voice Narration ──────────────────────────────────────────────────
# ElevenLabs (primary voice provider — voice preview, narration, voice design)
# Get your key: https://elevenlabs.io/ → Profile → API Key
ELEVENLABS_API_KEY=your-key-here

# OpenAI (fallback voice provider — simpler TTS, lower cost)
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-key-here

# ── AI Video Generation (optional) ──────────────────────────────────
# Google Veo 3 (cinematic AI video clips, ~$0.40-0.75/sec)
# Get your key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-key-here

# Runway Gen-3 Alpha (AI video clips, ~$0.50-1.00/clip)
# Get your key: https://app.runwayml.com/ → Settings → API Keys
RUNWAY_API_KEY=your-key-here

# ── YouTube Publishing (optional) ────────────────────────────────────
# Upload demo videos to your YouTube channel automatically.
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create a project (or use existing), enable YouTube Data API v3
# 3. Create OAuth 2.0 Client ID (Desktop app type)
# 4. Copy the client ID and secret below
YOUTUBE_CLIENT_ID=your-client-id-here
YOUTUBE_CLIENT_SECRET=your-client-secret-here
