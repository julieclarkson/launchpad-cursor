{
  "version": 2,
  "video": {
    "resolution": { "width": 1920, "height": 1080 },
    "codec": "libx264",
    "preset": "medium",
    "crf": 23,
    "pixelFormat": "yuv420p",
    "audioCodec": "aac",
    "audioBitrate": "128k",
    "maxFileSizeMB": 25,
    "fps": 30
  },
  "capture": {
    "viewport": { "width": 1920, "height": 1080 },
    "networkIdleTimeout": 15000,
    "settleDelay": 2000,
    "serverCheckTimeout": 10000,
    "allowedHosts": ["localhost", "127.0.0.1", "0.0.0.0"],
    "typingDelay": { "min": 50, "max": 80 }
  },
  "narration": {
    "defaultProvider": "elevenlabs",
    "defaultPreset": "dev-casual",
    "silencePadding_ms": 400,
    "maxRetries": 3,
    "retryDelay_ms": 1000
  },
  "visual": {
    "defaultTier": "remotion",
    "tiers": {
      "html": { "label": "HTML + CSS", "cost": "free", "description": "Clean motion graphics, code-driven" },
      "remotion": { "label": "Remotion", "cost": "free", "description": "React-based video, Lottie/Rive characters, Three.js 3D" },
      "remotion-plus-ai": { "label": "Remotion + AI clips", "cost": "paid", "description": "Remotion base with 1-2 AI cinematic clips" },
      "full-ai": { "label": "Full AI video", "cost": "paid", "description": "All scenes generated by AI video models" }
    },
    "defaultColorScheme": "dark-mode",
    "defaultAnimationStyle": "motion-graphics",
    "defaultDynamism": "moderate",
    "aiVideo": {
      "defaultProvider": "veo3",
      "providers": {
        "veo3": { "label": "Google Veo 3", "costPerSecond": "$0.40-0.75" },
        "runway": { "label": "Runway Gen-3 Alpha", "costPerClip": "$0.50-1.00" }
      }
    }
  },
  "demo": {
    "defaultPlatform": "all",
    "defaultTone": "storytelling",
    "defaultFocus": "end-to-end",
    "defaultStyle": "developer-authentic",
    "fullDuration_s": 60
  },
  "gif": {
    "maxWidth": 800,
    "fps": 15,
    "maxFileSizeMB": 10,
    "paletteColors": 256
  },
  "paths": {
    "configDir": ".demo-maker",
    "capturesDir": ".demo-maker/captures",
    "narrationDir": ".demo-maker/narration",
    "outputDir": "OUTPUT",
    "clipsDir": ".demo-maker/clips",
    "voicePreviewsDir": ".demo-maker/voice-previews",
    "remotionDir": "shared/remotion"
  }
}
