#!/bin/bash
# Case Study Maker — Activates case study tracking in the current project.
# Run from your project directory. Works with the plugin installed from GitHub.
#
# Usage:
#   cd /path/to/your-project
#   /path/to/case-study-maker/csm-init
#
# The script finds the plugin directory from its own location.

set -e

# Plugin dir = directory containing this script (works when cloned from GitHub)
PLUGIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PROJECT_DIR="$(pwd)"

# Allow running from plugin dir when developing the plugin itself (project === plugin)

if [ ! -f "$PLUGIN_DIR/rules/case-study-partner.mdc" ]; then
  echo "Error: Plugin files not found at $PLUGIN_DIR"
  echo "  Make sure you're running the csm-init from the Case Study Maker plugin directory."
  exit 1
fi

echo "Activating Case Study Maker in: $PROJECT_DIR"
echo ""

# Create .case-study directory structure
mkdir -p .case-study/media .case-study/templates
if [ ! -f .case-study/events.json ]; then
  echo '{ "version": 1, "events": [] }' > .case-study/events.json
fi

# Copy builtin templates and themes so generation works in any project (path-independent)
if [ ! -f .case-study/templates/portfolio/starter/template.html ]; then
  mkdir -p .case-study/templates/portfolio/starter/snippets
  cp -r "$PLUGIN_DIR/templates/portfolio/starter/"* .case-study/templates/portfolio/starter/ 2>/dev/null || true
  echo "  Copied portfolio starter template to .case-study/templates/"
fi
if [ ! -f .case-study/templates/marketing/starter/template.html ]; then
  mkdir -p .case-study/templates/marketing/starter
  cp -r "$PLUGIN_DIR/templates/marketing/starter/"* .case-study/templates/marketing/starter/ 2>/dev/null || true
  echo "  Copied marketing starter template to .case-study/templates/"
fi
if [ ! -f .case-study/templates/themes/default/variables.css ]; then
  mkdir -p .case-study/templates/themes
  cp -r "$PLUGIN_DIR/templates/themes/"* .case-study/templates/themes/ 2>/dev/null || true
  echo "  Copied themes to .case-study/templates/themes/"
fi
if [ ! -f .case-study/scripts/build-portfolio.js ]; then
  mkdir -p .case-study/scripts
  cp "$PLUGIN_DIR/scripts/build-portfolio.js" .case-study/scripts/build-portfolio.js 2>/dev/null || true
  echo "  Copied build script to .case-study/scripts/"
fi
if [ ! -f .case-study/scripts/generate-index-card.cjs ]; then
  mkdir -p .case-study/scripts
  cp "$PLUGIN_DIR/scripts/generate-index-card.cjs" .case-study/scripts/generate-index-card.cjs 2>/dev/null || true
  echo "  Copied generate-index-card script to .case-study/scripts/"
fi
# Copy hooks for seamless background capture (git post-commit)
mkdir -p .case-study/hooks
cp "$PLUGIN_DIR/hooks/scripts/check-commit.js" .case-study/hooks/check-commit.js 2>/dev/null || true
echo "  Copied hooks for background capture"
if [ ! -f .case-study/templates/pitch-deck/starter/template.html ]; then
  mkdir -p .case-study/templates/pitch-deck/starter
  cp -r "$PLUGIN_DIR/templates/pitch-deck/"* .case-study/templates/pitch-deck/ 2>/dev/null || true
  echo "  Copied pitch-deck template to .case-study/templates/"
fi

# Install rules (always-on partner + generate reservation)
mkdir -p .cursor/rules
cp "$PLUGIN_DIR/rules/case-study-partner.mdc" .cursor/rules/case-study-partner.mdc
[ -f "$PLUGIN_DIR/rules/generate-case-study.mdc" ] && cp "$PLUGIN_DIR/rules/generate-case-study.mdc" .cursor/rules/generate-case-study.mdc

# Copy commands so /case-study and slash commands work in chat
mkdir -p .cursor/commands
for cmd in "$PLUGIN_DIR/commands/"*.md; do
  [ -f "$cmd" ] && cp "$cmd" .cursor/commands/ 2>/dev/null || true
done
# Overlay local-dev commands if present (dev repo only)
[ -d "$PLUGIN_DIR/.cursor/commands" ] && for cmd in "$PLUGIN_DIR/.cursor/commands/"*.md; do
  [ -f "$cmd" ] && cp "$cmd" .cursor/commands/ 2>/dev/null || true
done || true

# Update .gitignore
touch .gitignore
grep -q '.case-study/' .gitignore 2>/dev/null || echo '.case-study/' >> .gitignore
grep -q 'case-study-partner.mdc' .gitignore 2>/dev/null || echo '.cursor/rules/case-study-partner.mdc' >> .gitignore
grep -q 'generate-case-study.mdc' .gitignore 2>/dev/null || echo '.cursor/rules/generate-case-study.mdc' >> .gitignore

# Install git post-commit hook for seamless capture (if this is a git repo)
if [ -d .git ] && [ -f .case-study/hooks/check-commit.js ]; then
  HOOK_FILE=".git/hooks/post-commit"
  if [ ! -f "$HOOK_FILE" ]; then
    echo '#!/bin/sh' > "$HOOK_FILE"
  fi
  if ! grep -q 'check-commit' "$HOOK_FILE" 2>/dev/null; then
    echo '' >> "$HOOK_FILE"
    echo '# Case Study Maker: capture commit metadata' >> "$HOOK_FILE"
    echo 'node .case-study/hooks/check-commit.js 2>/dev/null || true' >> "$HOOK_FILE"
    echo "  Installed git post-commit hook for background capture"
  fi
  chmod +x "$HOOK_FILE" 2>/dev/null || true
fi

echo "Done. Case Study Maker is active."
echo "  .case-study/          — event log, media, templates, scripts"
echo "  .cursor/rules/        — always-on AI partner rule"
echo "  .cursor/commands/     — /case-study hub and slash commands"
echo ""
echo "Start a new Cursor chat in this project. The AI will:"
echo "  - Notice architecture decisions, tradeoffs, risks, security work"
echo "  - Prompt reflections at natural moments"
echo "  - Suggest capturing screenshots at visual milestones"
echo ""
echo "Recent commits:"
git log --oneline -5 2>/dev/null || echo "  (not a git repo yet)"
